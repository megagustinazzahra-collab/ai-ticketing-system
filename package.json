{
  "name": "wms-ticketing",
  "version": "1.0.0",
  "description": "WMS Issue Ticketing System",
  "main": "dist/bin/www.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec sucrase-node app/bin/www.js",
    "build": "rimraf dist && sucrase ./app -d ./dist --transforms imports",
    "start": "node --max-old-space-size=4096 ./dist/bin/www.js",
    "migrate": "sequelize db:migrate",
    "migrate:undo": "sequelize db:migrate:undo",
    "seed": "sequelize db:seed:all",
    "test": "cross-env NODE_ENV=test mocha",
    "test:spec": "cross-env NODE_ENV=test mocha --reporter spec",
    "coverage": "cross-env NODE_ENV=test nyc mocha",
    "lint": "eslint app --ext .js"
  },
  "keywords": [],
  "author": "BADR Interactive",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "csrf-csrf": "^2.2.3",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "express-xss-sanitizer": "^2.0.2",
    "hbs": "^4.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "magic-bytes.js": "^1.13.0",
    "minio": "^8.0.7",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "redis": "^5.12.1",
    "sanitize-html": "^2.17.3",
    "sequelize": "^6.37.8",
    "sucrase": "^3.35.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0"
  },
  "nyc": {
    "require": [
      "@sucrase/register"
    ],
    "include": [
      "app/**/*.js"
    ],
    "exclude": [
      "app/bin/**"
    ],
    "reporter": [
      "text",
      "lcov"
    ],
    "all": false
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "nodemon": "^3.1.14",
    "nyc": "^18.0.0",
    "rimraf": "^5.0.10",
    "supertest": "^7.2.2"
  }
}
