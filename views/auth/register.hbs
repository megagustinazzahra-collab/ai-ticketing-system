{{#>layouts/_auth}}

<div class="card-header text-center border-0 pt-2 pb-0">
  <h4 class="mb-1" style="color: var(--primary-blue); font-weight: 700;">Buat Akun Reporter</h4>
  <p class="text-muted small mb-0">Lengkapi data diri Anda</p>
</div>

<div class="card-body pt-3">

  <form action="/register" method="POST" id="register-form">
    <input type="hidden" name="csrfToken" value="{{csrfToken}}">

    <!-- Nama -->
    <div class="form-group mb-3">
      <label class="small text-muted mb-1">Nama Lengkap <span class="text-danger">*</span></label>
      <input type="text" name="name" value="{{old.name}}"
        class="form-control form-control-sm {{#if errors.name}}is-invalid{{/if}}"
        placeholder="Nama lengkap" required>
      {{#if errors.name}}<div class="invalid-feedback">{{#each errors.name}}{{this}} {{/each}}</div>{{/if}}
    </div>

    <!-- Email -->
    <div class="form-group mb-3">
      <label class="small text-muted mb-1">Email <span class="text-danger">*</span></label>
      <input type="email" name="email" value="{{old.email}}"
        class="form-control form-control-sm {{#if errors.email}}is-invalid{{/if}}"
        placeholder="email@example.com" required>
      {{#if errors.email}}<div class="invalid-feedback">{{#each errors.email}}{{this}} {{/each}}</div>{{/if}}
    </div>

    <!-- Nama Fasyankes -->
    <div class="form-group mb-3">
      <label class="small text-muted mb-1">Nama Fasyankes / Entitas dan Lokasi <span class="text-danger">*</span></label>
      <input type="text" name="hospital_name" value="{{old.hospital_name}}"
        class="form-control form-control-sm {{#if errors.hospital_name}}is-invalid{{/if}}"
        placeholder="Contoh: RS Umum Daerah Kota Bandung" required>
      {{#if errors.hospital_name}}<div class="invalid-feedback">{{#each errors.hospital_name}}{{this}} {{/each}}</div>{{/if}}
    </div>

    <!-- No. HP -->
    <div class="form-group mb-3">
      <label class="small text-muted mb-1">Nomor HP</label>
      <input type="tel" name="phone" value="{{old.phone}}"
        class="form-control form-control-sm {{#if errors.phone}}is-invalid{{/if}}"
        placeholder="08xxxxxxxxxx — Opsional">
      {{#if errors.phone}}<div class="invalid-feedback">{{#each errors.phone}}{{this}} {{/each}}</div>{{/if}}
    </div>

    <!-- Password -->
    <div class="form-group mb-3">
      <label class="small text-muted mb-1">Password <span class="text-danger">*</span></label>
      <div class="input-group">
        <input type="password" name="password" id="password"
          class="form-control form-control-sm {{#if errors.password}}is-invalid{{/if}}"
          placeholder="Min. 8 karakter, huruf kapital, angka" required>
        <div class="input-group-append">
          <button class="btn btn-outline-secondary btn-sm" type="button" id="toggle-password" tabindex="-1">
            <i class="fas fa-eye" id="eye-icon"></i>
          </button>
        </div>
        {{#if errors.password}}<div class="invalid-feedback">{{#each errors.password}}{{this}} {{/each}}</div>{{/if}}
      </div>
    </div>

    <!-- Konfirmasi Password -->
    <div class="form-group mb-4">
      <label class="small text-muted mb-1">Konfirmasi Password <span class="text-danger">*</span></label>
      <input type="password" name="password_confirmation"
        class="form-control form-control-sm {{#if errors.password_confirmation}}is-invalid{{/if}}"
        placeholder="Ulangi password" required>
      {{#if errors.password_confirmation}}<div class="invalid-feedback">{{#each errors.password_confirmation}}{{this}} {{/each}}</div>{{/if}}
    </div>

    <button type="submit" class="btn btn-primary-action btn-block">
      <i class="fas fa-user-plus mr-2"></i>Daftar
    </button>
  </form>

  <div class="mt-3 text-center">
    <span class="text-muted small">Sudah punya akun?</span>
    <a href="/login" class="small ml-1" style="color: var(--accent-green);">Login di sini</a>
  </div>

</div>

<script>
  $('#toggle-password').on('click', function () {
    const input = $('#password')
    const isPass = input.attr('type') === 'password'
    input.attr('type', isPass ? 'text' : 'password')
    $('#eye-icon').toggleClass('fa-eye fa-eye-slash')
  })
</script>

{{/layouts/_auth}}
