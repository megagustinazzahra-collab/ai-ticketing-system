{{#>layouts/_auth}}

<div class="card-header text-center border-0 pt-2 pb-0">
  <h4 class="mb-1" style="color: var(--primary-blue); font-weight: 700;">Lupa Password</h4>
  <p class="text-muted small mb-0">Masukkan email untuk menerima link reset</p>
</div>

<div class="card-body pt-3">

  {{#if success}}
  <div class="alert alert-success py-2 small"><i class="fas fa-check-circle mr-1"></i>{{success}}</div>
  {{/if}}

  {{#if errors.email}}
  <div class="alert alert-danger py-2 small"><i class="fas fa-exclamation-circle mr-1"></i>{{#each errors.email}}{{this}}{{/each}}</div>
  {{/if}}

  <form action="/forgot-password" method="POST">
    <input type="hidden" name="csrfToken" value="{{csrfToken}}">

    <div class="form-group mb-4">
      <label class="small text-muted mb-1">Alamat Email <span class="text-danger">*</span></label>
      <div class="input-group">
        <input type="email" name="email"
          class="form-control {{#if errors.email}}is-invalid{{/if}}"
          placeholder="email@example.com" required>
        <div class="input-group-append">
          <div class="input-group-text"><i class="fas fa-envelope"></i></div>
        </div>
      </div>
    </div>

    <button type="submit" class="btn btn-primary-action btn-block">
      <i class="fas fa-paper-plane mr-2"></i>Kirim Link Reset
    </button>
  </form>

  <div class="mt-3 text-center">
    <a href="/login" class="small text-muted"><i class="fas fa-arrow-left mr-1"></i>Kembali ke Login</a>
  </div>

</div>

{{/layouts/_auth}}
