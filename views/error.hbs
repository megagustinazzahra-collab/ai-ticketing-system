<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{code}} — {{APP_NAME}}</title>
  <style>
    body { font-family: sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; background: #f4f6f9; }
    .box { text-align: center; padding: 40px; background: white; border-radius: 8px; box-shadow: 0 2px 10px rgba(0,0,0,.1); }
    h1 { font-size: 4rem; color: #1E3A5F; margin: 0; }
    p { color: #6c757d; }
    a { color: #2E75B6; text-decoration: none; }
  </style>
</head>
<body>
  <div class="box">
    <h1>{{code}}</h1>
    <h2>{{title}}</h2>
    <p>{{message}}</p>
    <a href="/">← Kembali ke Beranda</a>
  </div>
</body>
</html>
