{{#equal status 1}}<span class="badge badge-primary">Open</span>{{/equal}}
{{#equal status 2}}<span class="badge badge-info">In Progress</span>{{/equal}}
{{#equal status 3}}<span class="badge badge-warning">Pending</span>{{/equal}}
{{#equal status 4}}<span class="badge badge-success">Resolved</span>{{/equal}}
{{#equal status 5}}<span class="badge badge-secondary">Closed</span>{{/equal}}
{{#equal status 6}}<span class="badge badge-danger">Rejected</span>{{/equal}}
