<div class="d-flex justify-content-between align-items-center">
  <div>
    <h1 class="m-0 text-dark" style="font-size: 1.25rem; font-weight: 600;">{{title}}</h1>
    {{#if breadcrumb}}
    <ol class="breadcrumb float-sm-right m-0 p-0" style="background:none;">
      <li class="breadcrumb-item"><a href="/">Home</a></li>
      {{#each breadcrumb}}
      <li class="breadcrumb-item {{#if this.active}}active{{/if}}">
        {{#if this.url}}<a href="{{this.url}}">{{this.label}}</a>{{else}}{{this.label}}{{/if}}
      </li>
      {{/each}}
    </ol>
    {{/if}}
  </div>
  {{#if backUrl}}
  <a href="{{backUrl}}" class="btn btn-back btn-sm">
    <i class="fas fa-arrow-left mr-1"></i>Kembali
  </a>
  {{/if}}
</div>
